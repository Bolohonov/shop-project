<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V010-1" author="platform">
        <comment>Pending CRM tenant events — для случая когда событие пришло до регистрации юзера в shop</comment>
        <createTable tableName="pending_crm_tenants">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_pending_crm_tenants_email"/>
            </column>
            <column name="tenant_schema" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="received_at" type="TIMESTAMPTZ" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="pending_crm_tenants"/>
        </rollback>
    </changeSet>

</databaseChangeLog>