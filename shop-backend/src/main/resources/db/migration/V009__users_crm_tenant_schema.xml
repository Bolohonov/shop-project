<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V009-1" author="platform">
        <comment>Add crmTenantSchema to users — filled automatically via Kafka crm.tenant.created event</comment>
        <addColumn tableName="users">
            <column name="crm_tenant_schema" type="VARCHAR(255)"
                    remarks="Схема тенанта CRM — заполняется автоматически после регистрации в CRM"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="users" columnName="crm_tenant_schema"/>
        </rollback>
    </changeSet>

</databaseChangeLog>